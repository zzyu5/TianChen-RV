+#ifndef TCRV_GEMM_VERIFY
+#define TCRV_GEMM_VERIFY 0
+#endif
+
+#define TCRV_GEMM_ENABLED 1
+#else
+#define TCRV_GEMM_ENABLED 0
+#endif // riscv_v_intrinsic && zvfh
