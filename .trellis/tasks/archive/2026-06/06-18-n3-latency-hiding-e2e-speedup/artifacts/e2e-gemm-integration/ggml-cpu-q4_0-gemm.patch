+// ============================================================================
+// TianChen-RV q4_0 x q8_0 M-blocked prefill GEMM (decode amortization).
+//
+// Drop-in, BIT-EXACT acceleration of the q4_0 prefill (multi-column) matmul.
+// For PREFILL (>=2 activation columns) we decode each q4_0 weight block's
+// nibbles ONCE and reuse them across M q8_0 activation columns, instead of
+// re-decoding the weights for every (weight-row, activation-col) vec_dot.
+// The per-(row,col) reduction is unchanged -> the result is bit-exact to
+// ggml's ggml_vec_dot_q4_0_q8_0 (same per-block accumulation order).
+//
+// Validated micro-probe: ~1.56x over per-vec_dot at M=8 (n_embd=4096/n_ff=11008,
+// VLEN=128). See .trellis/tasks/06-18-n3-latency-hiding-e2e-speedup/artifacts/
+// failfast-gemm/{kernels.c,RESULTS.md} in the TianChen-RV repo.
+//
+// Gated to: q4_0 weights, q8_0 activations, num_rows_per_vec_dot==1 (no mmla),
+// M>=2 (decode (single-col GEMV) stays on ggml's path -- it is reduction-capped,
+// not our win, and M=1 in this kernel is ~0.80x = slower).
+// ============================================================================
+#if defined(__riscv) && defined(__riscv_v_intrinsic) && defined(__riscv_zvfh)
+#include <riscv_vector.h>
+
+#define TCRV_Q4_0_XS 18   // sizeof(block_q4_0): fp16 d + 16 packed nibbles
+#define TCRV_Q8_0_YS 34   // sizeof(block_q8_0): fp16 d + 32 int8 quants
+#define TCRV_GEMM_MAXM 16 // 16-col ggml block tile (blck_1)
+
+static_assert(TCRV_Q4_0_XS == sizeof(block_q4_0), "tcrv: block_q4_0 stride mismatch");
+static_assert(TCRV_Q8_0_YS == sizeof(block_q8_0), "tcrv: block_q8_0 stride mismatch");
+
+// Decode one weight block's 16 qs bytes -> v0,v1 (low/high nibble int8, -8 bias).
+#define TCRV_DECODE_W(xb, v0, v1, vl)                                                \
+    vuint8m1_t tx_##v0 = __riscv_vle8_v_u8m1((xb) + 2, (vl));                        \
+    vint8m1_t v0 = __riscv_vsub_vx_i8m1(                                             \
+        __riscv_vreinterpret_v_u8m1_i8m1(__riscv_vand_vx_u8m1(tx_##v0, 0x0F, (vl))), 8, (vl)); \
+    vint8m1_t v1 = __riscv_vsub_vx_i8m1(                                             \
+        __riscv_vreinterpret_v_u8m1_i8m1(__riscv_vsrl_vx_u8m1(tx_##v0, 0x04, (vl))), 8, (vl));
+
+// M-blocked GEMM. out[j] == ggml_vec_dot_q4_0_q8_0(weight_row, column_j) for
+// j in [0,M).  vyp is block-major packed: column j's block-ib q8_0 record at
+// vyp + (ib*M + j)*YS  (M columns' block-ib data contiguous).
+// This is kern_gemm (PRIMARY, scalar-fold) from the validated probe, verbatim.
+static void tcrv_gemm_q4_0_q8_0(size_t n, int M, float * out,
+                                const uint8_t * vx, const uint8_t * vyp) {
+    const int nb = (int)n / 32;
+    size_t vl = 16;
+    size_t fvl = (size_t)M;                          // M fp32 lanes (M<=16 -> m4)
+    vfloat32m4_t facc = __riscv_vfmv_v_f_f32m4(0.0f, fvl);
+    int32_t buf[TCRV_GEMM_MAXM];
+    float   dyf[TCRV_GEMM_MAXM];
+    for (int ib = 0; ib < nb; ++ib) {
+        const uint8_t * xb = vx + (size_t)ib * TCRV_Q4_0_XS;
+        TCRV_DECODE_W(xb, v0, v1, vl);                // decode weight block ONCE
+        float dx = (float)*(const _Float16 *)(xb);
+        const uint8_t * yblk = vyp + (size_t)ib * M * TCRV_Q8_0_YS;
+        for (int j = 0; j < M; ++j) {
+            const uint8_t * yb = yblk + (size_t)j * TCRV_Q8_0_YS;
+            vint8m1_t y0 = __riscv_vle8_v_i8m1((const int8_t *)(yb + 2), vl);
+            vint8m1_t y1 = __riscv_vle8_v_i8m1((const int8_t *)(yb + 2 + 16), vl);
+            vint16m2_t p = __riscv_vwmul_vv_i16m2(v0, y0, vl);   // reuse decoded v0/v1
+            p = __riscv_vwmacc_vv_i16m2(p, v1, y1, vl);
+            vint32m1_t z = __riscv_vmv_v_x_i32m1(0, vl);
+            // lane-0 vector store of the per-(block,col) reduction; NO vmv.x.s.
+            __riscv_vse32_v_i32m1(buf + j, __riscv_vwredsum_vs_i16m2_i32m1(p, z, vl), 1);
+            dyf[j] = (float)*(const _Float16 *)(yb);
+        }
+        // ONE vectorised fp32 fold over all M columns for this block.
+        vfloat32m4_t sumiv  = __riscv_vfcvt_f_x_v_f32m4(__riscv_vle32_v_i32m4(buf, fvl), fvl);
+        vfloat32m4_t scalev = __riscv_vfmul_vf_f32m4(__riscv_vle32_v_f32m4(dyf, fvl), dx, fvl);
+        facc = __riscv_vfmacc_vv_f32m4(facc, sumiv, scalev, fvl);
+    }
+    __riscv_vse32_v_f32m4(out, facc, fvl);
+}
