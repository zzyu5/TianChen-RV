# POS: #include <riscv_vector.h>
# POS: /* selected_kernel: @rvv_microkernel_manifest */
# POS: /* selected_variant: @rvv_first_slice */
# POS: /* selected_role: direct variant */
# POS: /* selected_march: rv64gcv */
# POS: /* selected_mabi: lp64d */
# POS: /* lowering_boundary: tcrv_rvv.lowering_boundary */
# POS: /* executable_microkernel: tcrv_rvv.i32_vadd_microkernel */
# POS: __riscv_vsetvl_e32m1
# POS: __riscv_vle32_v_i32m1
# POS: __riscv_vadd_vv_i32m1
# POS: __riscv_vse32_v_i32m1
# POS: printf("tcrv_rvv_microkernel_ok elements=%zu\n", (size_t)16);

