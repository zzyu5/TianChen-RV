# RUN: FileCheck %s --check-prefix=POS --implicit-check-not=emission_manifest --implicit-check-not=runtime_success --implicit-check-not=throughput --implicit-check-not=latency --implicit-check-not=artifacts/tmp --implicit-check-not=password --implicit-check-not=token < %t.generic.c

# POS: /* TianChen-RV RVV explicit microkernel C export. */
