# RUN: tcrv-opt %S/../EmissionManifest/emission-manifest-rvv-microkernel.mlir --tcrv-materialize-selected-lowering-boundaries --tcrv-materialize-emission-plans > %t.rvv-microkernel-post-planning.mlir
