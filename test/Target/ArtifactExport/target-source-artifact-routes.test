# RUN: tcrv-opt %S/../EmissionManifest/emission-manifest-rvv-microkernel.mlir --tcrv-materialize-selected-lowering-boundaries --tcrv-materialize-emission-plans > %t.rvv-microkernel-post-planning.mlir
# RUN: FileCheck %s --check-prefix=RVV-PLAN --implicit-check-not="status = \"supported\"" < %t.rvv-microkernel-post-planning.mlir
# RUN: not tcrv-translate --tcrv-export-rvv-microkernel-c %t.rvv-microkernel-post-planning.mlir 2>&1 | FileCheck %s --check-prefix=RVV-DIRECT-ROUTE-DELETED --implicit-check-not="#include <riscv_vector.h>" --implicit-check-not="__riscv_"
# RUN: not tcrv-translate --tcrv-export-target-source-artifact %t.rvv-microkernel-post-planning.mlir 2>&1 | FileCheck %s --check-prefix=GENERIC-SOURCE-FRONT-DOOR-DELETED --implicit-check-not="#include <riscv_vector.h>" --implicit-check-not="__riscv_"

# RVV-PLAN: emission_kind = "rvv-unsupported-metadata-boundary"
# RVV-PLAN-SAME: lowering_pipeline = "rvv-none-executable-unsupported"
# RVV-PLAN-SAME: message = "RVV first slice has no materialized EmitC lowering, runtime ABI, artifact contract, or executable emission path"
# RVV-PLAN-SAME: role = "direct variant"
# RVV-PLAN-SAME: runtime_abi_kind = "unsupported-plugin-runtime-abi"
# RVV-PLAN-SAME: status = "unsupported"
# RVV-PLAN-SAME: target = @rvv_first_slice
# RVV-DIRECT-ROUTE-DELETED: Unknown command line argument '--tcrv-export-rvv-microkernel-c'
# GENERIC-SOURCE-FRONT-DOOR-DELETED: Unknown command line argument '--tcrv-export-target-source-artifact'
