# REQUIRES: tianchenrv-local-riscv-object-clang, tianchenrv-local-native-clangxx
# RUN: rm -rf %t.evidence
# RUN: python3 %S/../../../scripts/tensorextlite_runtime_abi_e2e.py --artifact-root %t.evidence --run-id lit --input %S/../../Transforms/TensorExtLite/tensorext-lite-fragment-mma-source-front-door.mlir --tcrv-opt tcrv-opt --tcrv-translate tcrv-translate --clangxx clang++ --llvm-readobj llvm-readobj | FileCheck %s

# CHECK: tianchenrv.tensorext_lite.runtime_abi_e2e: PASS
# CHECK: selected_variant: tensorext_lite_tile_mma_first_slice
# CHECK: origin_plugin: tensorext-lite-plugin
# CHECK: construction_protocol: extension-family-construction-protocol.v1
# CHECK: emitc_route: tensorext-lite-fragment-mma-emitc-route
# CHECK: runtime_abi_name: tensorext-lite-fragment-mma-runtime-c-abi.v1
# CHECK: runtime_abi_parameter_count: 0
# CHECK: target_bundle_component_group: tensorext-lite-fragment-mma-materialized-emitc-bundle.v1
# CHECK: target_bundle_object_format: elf64-littleriscv
# CHECK: target_bundle_object_arch: riscv64
# CHECK: native_call_trace: configure,load_frag,tile_mma,store_frag
