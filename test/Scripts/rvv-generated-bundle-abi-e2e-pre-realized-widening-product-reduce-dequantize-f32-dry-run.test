# The deferred-wide single-scope body emits NO low_precision_resource.* selection
# block and NO gearbox.producer/consumer_scope / gearbox_cross_region_handoff
# facts (those are the narrow grouped two-scope candidate artifacts); the
# --implicit-check-not lines below fail-close if a stale narrow resource/handoff
# fact leaks into the wide evidence.
# WPRD-DAG: "widening_product_reduction_boundary"
# WPRD-DAG: "deferred_wide_accumulate": true
# WPRD-DAG: "loop_accumulator_source": "dot_acc_vec"
# WPRD-DAG: "loop_updates_vector_carry": true
# WPRD-DAG: "loop_deferred_accumulate_intrinsic": "__riscv_vwadd_wv_i32m8"
# WPRD-DAG: "post_loop_single_reduce_intrinsic": "__riscv_vredsum_vs_i32m8_i32m1"
# WPRD-DAG: "post_loop_scalar_extract": "v{{[0-9]+}}"
# WPRD-DAG: "scalar_dequant_expression": "(acc[0] + dot_acc_scalar) * scale"
# WPRD-DAG: "forbids_vector_convert_intrinsic": "__riscv_vfcvt_f_x_v_f32m1"
# WPRD-DAG: "forbids_vector_scale_intrinsic": "__riscv_vfmul_vf_f32m1"
# WPRD-DAG: "dequantization_boundary"
# WPRD-DAG: "provider_route_facts"
