# the result config + route identity / leaf-profile / c_type_mapping stay the
# narrow-named logical-route strings.
# WPRD-DAG: "key": "tcrv_rvv.product_vector_c_type"
# WPRD-DAG: "value": "vint16m4_t"
# WPRD-DAG: "key": "tcrv_rvv.widening_product_relation"
# WPRD-DAG: "value": "signed-i8m2xi8m2-to-i16m4"
# WPRD-DAG: "key": "tcrv_rvv.product_reduction_chain_relation"
