# RUN: FileCheck %s --check-prefix=ROOT --implicit-check-not="descriptor" --implicit-check-not="direct-C" --implicit-check-not="source-export" < %t.artifacts/direct-pre-realized-route-entry/evidence.json
# RUN: FileCheck %s --check-prefix=CMP --implicit-check-not="--tcrv-materialize-selected-lowering-boundaries" --implicit-check-not="descriptor" --implicit-check-not="direct-C" --implicit-check-not="source-export" --implicit-check-not="source-front-door" --implicit-check-not="tcrv_rvv.i32_" < %t.artifacts/direct-pre-realized-route-entry/cmp_select/evidence.json
# RUN: FileCheck %s --check-prefix=HARNESS-CMP --implicit-check-not="descriptor" --implicit-check-not="direct-C" --implicit-check-not="source-export" < %t.artifacts/direct-pre-realized-route-entry/cmp_select/rvv_generated_bundle_abi_cmp_select_harness.c

# STDOUT: rvv_generated_bundle_abi_e2e: dry_run_success
# STDOUT: artifact_dir:

# ROOT-DAG: "input_mode": "pre-realized-selected-body"
# ROOT-DAG: "pre_realized_route_entry_mode": "direct"
# ROOT-DAG: "cmp_select"
# ROOT-DAG: "ssh_evidence": false
# ROOT-DAG: "status": "dry_run_success"

# CMP-DAG: "input_mode": "pre-realized-selected-body"
# CMP-DAG: "path": "{{.*}}test/Target/RVV/pre-realized-selected-body-artifact-cmp-select.mlir"
# CMP-DAG: "expected_selected_variant": "pre_realized_body_rvv_cmp_select"
# CMP-DAG: "expected_runtime_abi_name": "rvv-generic-cmp-select-callable-c-abi.v1"
# CMP-DAG: "front_door": "pre-realized-selected-tcrv-exec-rvv-body"
# CMP-DAG: "materializer": "rvv-route-entry-selected-body-realization"
# CMP-DAG: "route_entry_realization": true
# CMP-DAG: "pre_realized_body_consumed": true
# CMP-DAG: "key": "rvv_emitc_lowerable_route"
# CMP-DAG: "value": "rvv-generic-cmp-select-emitc-route"
# CMP-DAG: "key": "rvv_selected_body_operation"
# CMP-DAG: "value": "cmp_select"
# CMP-DAG: "key": "rvv_selected_body_typed_compute_op"
# CMP-DAG: "value": "tcrv_rvv.select"
# CMP-DAG: "predicate_coverage_contract": "multi-lane cmp_select cases require predicate true and false lanes"
# CMP-DAG: --tcrv-materialize-emission-plans
# CMP-DAG: --tcrv-export-target-artifact-bundle
# CMP-DAG: "status": "dry_run_success"

# HARNESS-CMP: tcrv_emitc_pre_realized_body_cmp_select_kernel_pre_realized_body_rvv_cmp_select(lhs, rhs, out, n);
# HARNESS-CMP: predicate_true_lanes
# HARNESS-CMP: predicate_false_lanes
# HARNESS-CMP: (lhs[index] == rhs[index] ? lhs[index] : rhs[index])
# HARNESS-CMP: PASS op=cmp_select counts=7,16,23
