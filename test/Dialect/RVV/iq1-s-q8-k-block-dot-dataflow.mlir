// RUN: tcrv-opt %s --split-input-file --verify-diagnostics | FileCheck %s

// The tcrv_rvv.iq1_s_q8_k_block_dot op makes the COMPLETE ggml ggml_vec_dot_iq1_s_q8_K
// TERNARY-grid super-block dot-product STRUCTURE first-class in the typed RVV body --
// the TERNARY class, the LAST common ggml dot kernel (only iq1_m, its sibling, remains).
// It REUSES the grid-codebook indexed-lookup integer core (packed-uint64 GRID lookup,
// the signed widening product + chained vwredsum, the integer accumulation, the
// per-super-block fp32 fold) but adds the GENUINELY NEW per-block DELTA mechanism. The
// 2048-entry TERNARY grid is byte-viewed as signed int8 (0xff -> -1), so there is NO
// sign plane / kmask; the scale lives in the uint16 qh word (ls = 2*((qh>>12)&7)+1); the
// 11-bit index idx = qs[ib*4+l] | (((qh>>3l)&7)<<8); the DELTA term delta = (qh&0x8000)
// ? -1 : 1 folds via the q8 bsums (sumi1 += ls*delta*(bsums[2ib]+bsums[2ib+1])); the
// 0.125f (IQ1S_DELTA) applies ONCE inside the fold; *s = sumf. It consumes the iq1_s
// weight base (vx), the q8_K activation base (vy), the fp32 output (s), the runtime
// element count (n), and the active vl token, and carries the super-block-format
// structural facts PLUS the grid (2048 int64) table as a typed attr (I4 mirror). The
// verifier is fail-closed (I7) on a wrong kind / scale model / block-format fact / grid
// size / operand C type. iq1_s has NO sign plane and NO explicit scales[] array.

// CHECK-LABEL: tcrv.exec.kernel @iq1_s_q8_k_block_dot_accepts_ggml_abi

module {
  tcrv.exec.kernel @iq1_s_q8_k_block_dot_accepts_ggml_abi {
    tcrv.exec.variant @rvv attributes {origin = "rvv-plugin", requires = []} {
      %n = tcrv_rvv.runtime_abi_value {c_name = "n", c_type = "size_t", ownership = "target-export-abi-owned", purpose = "n", role = "runtime-element-count"} : index
      %s = tcrv_rvv.runtime_abi_value {c_name = "s", c_type = "float *", ownership = "target-export-abi-owned", purpose = "out", role = "output-buffer"} : !tcrv_rvv.runtime_abi_value
      %vx = tcrv_rvv.runtime_abi_value {c_name = "vx", c_type = "const uint8_t *", ownership = "target-export-abi-owned", purpose = "iq1s-weight", role = "lhs-input-buffer"} : !tcrv_rvv.runtime_abi_value
      %vy = tcrv_rvv.runtime_abi_value {c_name = "vy", c_type = "const uint8_t *", ownership = "target-export-abi-owned", purpose = "q8k-act", role = "rhs-input-buffer"} : !tcrv_rvv.runtime_abi_value
      %vl = tcrv_rvv.setvl %n {lmul = "m1", policy = #tcrv_rvv.policy<tail = agnostic, mask = agnostic>, sew = 32 : i64} : index -> !tcrv_rvv.vl
      tcrv_rvv.with_vl %vl attributes {lmul = "m1", origin = "rvv-plugin", policy = #tcrv_rvv.policy<tail = agnostic, mask = agnostic>, required_capabilities = [], rvv_construction_protocol = "extension-family-construction-protocol.v1", selected_path_role = "dispatch case", selected_variant = @rvv, sew = 32 : i64, source_kernel = "iq1_s_q8_k_block_dot_accepts_ggml_abi", status = "selected-lowering-boundary"} {
